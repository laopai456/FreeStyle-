<Window x:Class="FS服装搭配专家.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FS服装搭配专家.UI.Windows"
        Title="FreeStyle"
        Height="768"
        Width="1440"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="{DynamicResource WindowBackgroundColor}"
        ShowInTaskbar="True">
    <Window.Resources>
        <!-- 全局去掉虚线焦点框，改为高亮反馈 -->
        <Style TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <!-- 主题画刷资源 -->
        <SolidColorBrush x:Key="PanelBackgroundColor" Color="#B0FFFFFF" />
        <SolidColorBrush x:Key="HeaderBackgroundColor" Color="#90FFFFFF" />
        <SolidColorBrush x:Key="WindowBackgroundColor" Color="#6a85b6" />
        <SolidColorBrush x:Key="LogBackgroundColor" Color="#A0FFFFFF" />
        <SolidColorBrush x:Key="AccentColor" Color="#D65565" />
        <SolidColorBrush x:Key="ScrollBarThumbColor" Color="#996a85b6" />
        <SolidColorBrush x:Key="TabUnselectedForegroundColor" Color="#8892AB" />
        <SolidColorBrush x:Key="CardBorderColor" Color="#D1D7E8" />
        <SolidColorBrush x:Key="SlotCardBackgroundColor" Color="#C0FFFFFF" />
        <SolidColorBrush x:Key="SlotIconBackgroundColor" Color="#B0FFFFFF" />
        <SolidColorBrush x:Key="SlotEmptyTextColor" Color="#8892AB" />
        <SolidColorBrush x:Key="SlotCategoryTextColor" Color="#4A536B" />
        <SolidColorBrush x:Key="SlotItemNameTextColor" Color="#4A536B" />
        <SolidColorBrush x:Key="SlotEffectTextColor" Color="#8892AB" />
        <SolidColorBrush x:Key="SlotSelectedBorderColor" Color="#8999BC" />
        <SolidColorBrush x:Key="ListItemBackgroundColor" Color="#10FFFFFF" />
        <SolidColorBrush x:Key="ListItemHoverBackgroundColor" Color="#30000000" />
        <SolidColorBrush x:Key="ListItemSelectedBackgroundColor" Color="#40000000" />
        <SolidColorBrush x:Key="InfoMessageColor" Color="#D65565" />
        <!-- 按钮相关画刷（确保模板触发器能解析） -->
        <SolidColorBrush x:Key="ButtonGlassColor" Color="#30FFFFFF" />
        <SolidColorBrush x:Key="ButtonForegroundColor" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="HoverBackgroundColor" Color="#40000000" />
        <SolidColorBrush x:Key="PressedBackgroundColor" Color="#60000000" />
        <SolidColorBrush x:Key="TabHoverBackgroundColor" Color="#30000000" />
        <SolidColorBrush x:Key="TabSelectedBackgroundColor" Color="#40000000" />
        <SolidColorBrush x:Key="TabSelectedForegroundColor" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="TextBoxBackgroundColor" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="TextBoxForegroundColor" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="TextBoxBorderColor" Color="#4DFFFFFF" />
        <SolidColorBrush x:Key="StatusTextColor" Color="#FF999999" />
        <SolidColorBrush x:Key="TitleTextColor" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="BodyTextColor" Color="#E6FFFFFF" />

        <!-- 标题流动渐变画刷 -->
        <LinearGradientBrush x:Key="TitleGradientBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop x:Name="gs1" Color="#FF667EEA" Offset="0" />
            <GradientStop x:Name="gs2" Color="#FF6DD5FA" Offset="0.5" />
            <GradientStop x:Name="gs3" Color="#FFC58AF9" Offset="1" />
        </LinearGradientBrush>

        <!-- 标题流动渐变动画：5秒循环 -->
        <Storyboard x:Key="TitleFlowAnimation" RepeatBehavior="Forever">
            <PointAnimation Storyboard.TargetName="TitleGradientBg"
                            Storyboard.TargetProperty="StartPoint"
                            From="-1,0.5" To="2,0.5" Duration="0:0:5" AutoReverse="True" />
            <PointAnimation Storyboard.TargetName="TitleGradientBg"
                            Storyboard.TargetProperty="EndPoint"
                            From="0,0.5" To="3,0.5" Duration="0:0:5" AutoReverse="True" />
        </Storyboard>

        <!-- 统一按钮：深灰底白字，高度 32px，间距 16px -->
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="local:RippleEffect.Enable" Value="True" />
            <Setter Property="Background" Value="{DynamicResource ButtonGlassColor}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- 流光边框层 -->
                            <Border x:Name="StreamBorder" CornerRadius="7"
                                    BorderThickness="1.5" Opacity="0">
                                <Border.BorderBrush>
                                    <LinearGradientBrush x:Name="StreamBrush"
                                                         StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#00667EEA" Offset="0"/>
                                        <GradientStop Color="#FF667EEA" Offset="0.1"/>
                                        <GradientStop Color="#FF6DD5FA" Offset="0.3"/>
                                        <GradientStop Color="#FFC58AF9" Offset="0.5"/>
                                        <GradientStop Color="#00C58AF9" Offset="0.6"/>
                                        <GradientStop Color="#00667EEA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                            </Border>
                            <!-- 主内容 -->
                            <Border x:Name="ButtonBorder" CornerRadius="6"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0" Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Grid ClipToBounds="True">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      TextElement.FontSize="{TemplateBinding FontSize}" />
                                    <Canvas x:Name="RippleCanvas" IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StreamBorder" Property="Opacity" Value="1"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource HoverBackgroundColor}" />
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource PressedBackgroundColor}" />
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource HoverBackgroundColor}" />
                            </Trigger>
                            <!-- 流光动画：鼠标进入开始，离开停止 -->
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard x:Name="StreamSB">
                                    <Storyboard RepeatBehavior="Forever">
                                        <PointAnimation Storyboard.TargetName="StreamBrush"
                                                        Storyboard.TargetProperty="StartPoint"
                                                        From="-1,0.5" To="2,0.5" Duration="0:0:1.5"/>
                                        <PointAnimation Storyboard.TargetName="StreamBrush"
                                                        Storyboard.TargetProperty="EndPoint"
                                                        From="0,0.5" To="3,0.5" Duration="0:0:1.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <RemoveStoryboard BeginStoryboardName="StreamSB"/>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 搜索框：深色底 -->
        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource TextBoxBackgroundColor}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBoxForegroundColor}" />
            <Setter Property="CaretBrush" Value="{DynamicResource StatusTextColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TextBoxBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,4" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 滚动条 -->
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="2">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource ScrollBarThumbColor}" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 列表样式：深色 -->
        <Style x:Key="GearListBox" TargetType="ListBox">
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.ScrollUnit="Pixel">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}" />
                            </ScrollViewer.Resources>
                            <ItemsPresenter VerticalAlignment="Top" HorizontalAlignment="Stretch" />
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Padding" Value="6,3" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{DynamicResource ListItemBackgroundColor}" Padding="{TemplateBinding Padding}"
                                            CornerRadius="3" Margin="0,1" BorderThickness="3,0,0,0" BorderBrush="Transparent"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundColor}" />
                                            <Setter TargetName="Bd" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundColor}" />
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentColor}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab 按钮：深色版 -->
        <Style x:Key="TabButton" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TabUnselectedForegroundColor}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4,4,0,0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabHoverBackgroundColor}" />
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabSelectedBackgroundColor}" />
                                <Setter Property="Foreground" Value="{DynamicResource TabSelectedForegroundColor}" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabHoverBackgroundColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox 主题感知样式 -->
        <Style x:Key="ThemeComboBox" TargetType="ComboBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="{DynamicResource TextBoxBackgroundColor}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBoxForegroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TextBoxBorderColor}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <Grid Margin="6,0">
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left" />
                                    <Path x:Name="Arrow" Data="M0,0 L4,4 L8,0"
                                          Stroke="{DynamicResource TextBoxForegroundColor}"
                                          StrokeThickness="1.5"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,4,0" />
                                </Grid>
                            </Border>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="false" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0"
                                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource TextBoxBackgroundColor}"
                                        BorderBrush="{DynamicResource TextBoxBorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,2,0,0"
                                        MaxHeight="200">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem 主题感知样式 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBoxForegroundColor}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundColor}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 无边框开关滑块样式 -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource StatusTextColor}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Root" Background="Transparent" Padding="2,0" CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="SwitchTrack" Width="36" Height="18" CornerRadius="9"
                                        Background="#40FFFFFF" Margin="0,0,6,0">
                                    <Border x:Name="SwitchThumb" Width="14" Height="14" CornerRadius="7"
                                            Background="White" HorizontalAlignment="Left" Margin="2,0,0,0" />
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  TextElement.FontSize="{TemplateBinding FontSize}" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#FF6DD5FA" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,2,0" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#20FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 窗口控制按钮样式（无边框模式） -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource StatusTextColor}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF" />
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#50FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主布局 -->
    <Grid x:Name="mainGrid" Margin="6">
        <Grid.Background>
            <LinearGradientBrush x:Name="bgBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="bgStop1" Color="#6a85b6" Offset="0" />
                <GradientStop x:Name="bgStop2" Color="#bac8e0" Offset="0.5" />
                <GradientStop x:Name="bgStop3" Color="#f0c9e8" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 顶栏 -->
            <RowDefinition Height="Auto" />  <!-- 搜索通栏 -->
            <RowDefinition Height="*" />     <!-- 主内容 -->
            <RowDefinition Height="Auto" />  <!-- 底部按钮 -->
            <RowDefinition Height="Auto" />  <!-- 日志面板 -->
        </Grid.RowDefinitions>

        <!-- 视频背景层（主题为 video 类型时显示） -->
        <Image x:Name="VideoBackgroundImage"
               Stretch="UniformToFill"
               Visibility="Collapsed"
               Opacity="0.85"
               Grid.RowSpan="5" />

        <!-- ===== 顶栏 ===== -->
        <Grid x:Name="topBar" Grid.Row="0" Margin="4,8,4,4" Height="32"
              MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="3.8*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧标题：与服装列表道具文本左对齐 -->
            <Grid Grid.Column="0" Margin="10,0,0,0" ClipToBounds="True">
                <!-- 粒子背景 -->
                <Canvas IsHitTestVisible="False">
                    <!-- 粒子 1：亮白 -->
                    <Ellipse Width="5" Height="5" Fill="#CCFFFFFF" Canvas.Left="20" Canvas.Top="14" Opacity="0.7">
                        <Ellipse.Effect><BlurEffect Radius="3"/></Ellipse.Effect>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="20" To="260" Duration="0:0:5" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="8" To="24" Duration="0:0:3.5" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.4" To="0.9" Duration="0:0:2" AutoReverse="True"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <!-- 粒子 2：亮青 -->
                    <Ellipse Width="4" Height="4" Fill="#FF6DD5FA" Canvas.Left="80" Canvas.Top="8" Opacity="0.6">
                        <Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="80" To="300" Duration="0:0:6" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="6" To="26" Duration="0:0:4" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="0.8" Duration="0:0:3" AutoReverse="True"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <!-- 粒子 3：亮紫 -->
                    <Ellipse Width="6" Height="6" Fill="#DDC58AF9" Canvas.Left="150" Canvas.Top="20" Opacity="0.6">
                        <Ellipse.Effect><BlurEffect Radius="4"/></Ellipse.Effect>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="150" To="30" Duration="0:0:4.5" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="4" To="28" Duration="0:0:3" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="0.85" Duration="0:0:2.5" AutoReverse="True"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <!-- 粒子 4：亮蓝 -->
                    <Ellipse Width="4" Height="4" Fill="#FF667EEA" Canvas.Left="220" Canvas.Top="12" Opacity="0.6">
                        <Ellipse.Effect><BlurEffect Radius="3"/></Ellipse.Effect>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="220" To="50" Duration="0:0:7" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="10" To="22" Duration="0:0:2.5" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.35" To="0.9" Duration="0:0:1.8" AutoReverse="True"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <!-- 粒子 5：大白 -->
                    <Ellipse Width="5" Height="5" Fill="#EEFFFFFF" Canvas.Left="100" Canvas.Top="18" Opacity="0.5">
                        <Ellipse.Effect><BlurEffect Radius="3"/></Ellipse.Effect>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="100" To="280" Duration="0:0:5.5" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="16" To="4" Duration="0:0:3.8" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="0.85" Duration="0:0:2.2" AutoReverse="True"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <!-- 粒子 6：亮紫 -->
                    <Ellipse Width="4" Height="4" Fill="#DDC58AF9" Canvas.Left="280" Canvas.Top="10" Opacity="0.55">
                        <Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="280" To="60" Duration="0:0:6.5" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="8" To="24" Duration="0:0:4.2" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="0.8" Duration="0:0:2.8" AutoReverse="True"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <!-- 粒子 7：亮青（小） -->
                    <Ellipse Width="3" Height="3" Fill="#FF6DD5FA" Canvas.Left="190" Canvas.Top="6" Opacity="0.5">
                        <Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="190" To="340" Duration="0:0:4" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="4" To="28" Duration="0:0:3.2" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="0.9" Duration="0:0:1.5" AutoReverse="True"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <!-- 粒子 8：亮白（大） -->
                    <Ellipse Width="7" Height="7" Fill="#BBFFFFFF" Canvas.Left="50" Canvas.Top="22" Opacity="0.45">
                        <Ellipse.Effect><BlurEffect Radius="5"/></Ellipse.Effect>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="50" To="240" Duration="0:0:8" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="20" To="6" Duration="0:0:5" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="0.7" Duration="0:0:3" AutoReverse="True"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Canvas>

                <!-- 标题内容 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtTitle" Text="FreeStyle v2.0" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TitleTextColor}" VerticalAlignment="Center"
                               Cursor="Hand" MouseLeftButtonDown="txtTitle_MouseLeftButtonDown">
                        <TextBlock.Resources>
                            <LinearGradientBrush x:Key="TitleGradientBg" x:Name="TitleGradientBg" StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#FF667EEA" Offset="0" />
                                <GradientStop Color="#FF6DD5FA" Offset="0.5" />
                                <GradientStop Color="#FFC58AF9" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Resources>
                    </TextBlock>
                    <TextBlock x:Name="labStatus" Text="  未连接" FontSize="12"
                               Foreground="{DynamicResource BodyTextColor}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    <TextBlock x:Name="labErrorMsg" Text="" FontSize="12" Foreground="{DynamicResource AccentColor}"
                               Visibility="Collapsed" VerticalAlignment="Center" Margin="12,0,0,0" />
                    <TextBlock x:Name="labLoadingStatus" Text="" FontSize="12" Foreground="{DynamicResource BodyTextColor}"
                               Visibility="Collapsed" VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
            </Grid>
            <!-- 右侧按钮：与刷新穿搭文字右对齐 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="12,0,8,0">
                <CheckBox x:Name="chkLog" Content="日志" FontSize="12" Foreground="{DynamicResource StatusTextColor}"
                          VerticalAlignment="Center"
                          Checked="chkLog_Checked" Unchecked="chkLog_Unchecked" />
                <Button x:Name="btnLaunch" Content="🚀 启动游戏"
                        Style="{StaticResource GlassButton}" Click="btnLaunch_Click" Margin="16,0,0,0" />
                <Button x:Name="btnSkin" Content="🎨 换肤"
                        Style="{StaticResource GlassButton}" Click="btnSkin_Click" Margin="16,0,0,0" />
                <!-- 无边框模式开关 -->
                <CheckBox x:Name="chkBorderless" Content="无边框" Style="{StaticResource ToggleSwitch}"
                          Margin="16,0,0,0" ToolTip="切换无边框/有边框窗口模式"
                          FocusVisualStyle="{x:Null}"
                          Checked="chkBorderless_Checked" Unchecked="chkBorderless_Unchecked" />
                <!-- 视频模式透明度滑块 -->
                <Border x:Name="videoOpacityPanel" Visibility="Collapsed" Margin="24,0,16,0"
                        Height="32" VerticalAlignment="Center">
                    <Slider x:Name="sliderVideoOpacity" Width="80" Minimum="0" Maximum="100" Value="67"
                            VerticalAlignment="Center" ToolTip="调节UI覆盖层透明度" FocusVisualStyle="{x:Null}"
                            ValueChanged="sliderVideoOpacity_ValueChanged" />
                </Border>
                <!-- 无边框模式窗口控制按钮 -->
                <StackPanel x:Name="windowControls" Orientation="Horizontal" Visibility="Collapsed" Margin="8,0,0,0">
                    <Button x:Name="btnWinMin" Content="─" Style="{StaticResource WinCtrlButton}" Click="btnWinMin_Click" />
                    <Button x:Name="btnWinMax" Content="□" Style="{StaticResource WinCtrlButton}" Click="btnWinMax_Click" Margin="2,0" />
                    <Button x:Name="btnWinClose" Content="✕" Click="btnWinClose_Click" Width="36" Height="28" FontSize="14" Cursor="Hand"
                            Background="Transparent" Foreground="{DynamicResource StatusTextColor}" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="{DynamicResource StatusTextColor}" TextElement.FontSize="14" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E0D65565" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#D65565" />
                                    </Trigger>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ===== 搜索通栏 + 刷新 ===== -->
        <Grid Grid.Row="1" Margin="4,4,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="3.8*" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtSearch" Grid.Column="0"
                     Style="{StaticResource SearchTextBox}" Height="32" Margin="0,0,4,0"
                     ToolTip="搜索服装名称或编码"
                     TextChanged="txtSearch_TextChanged" />

            <DockPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                <TextBlock Text="变更区域" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TitleTextColor}"
                           VerticalAlignment="Center" DockPanel.Dock="Left" />
                <TextBlock x:Name="txtPairStatus" Text="" FontSize="11" Foreground="{DynamicResource StatusTextColor}"
                           VerticalAlignment="Center" Margin="4,0,0,0" DockPanel.Dock="Left" />
                <Button x:Name="btnRefresh" Content="🔄 刷新穿搭"
                        Style="{StaticResource GlassButton}" Click="btnRefresh_Click"
                        HorizontalAlignment="Right" />
            </DockPanel>
        </Grid>

        <!-- ===== 主内容区 ===== -->
        <Grid Grid.Row="2" Margin="4,0,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="3.8*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：Tab + 深色列表 -->
            <Border Grid.Column="0" Background="{DynamicResource PanelBackgroundColor}" CornerRadius="6" Margin="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Tab 头 -->
                    <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundColor}" CornerRadius="6,6,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <RadioButton x:Name="tabClothing" Content="👕 服装" GroupName="ListTab"
                                             Style="{StaticResource TabButton}" IsChecked="True"
                                             Checked="TabClothing_Checked" />
                                <RadioButton x:Name="tabEffect" Content="✨ 特效" GroupName="ListTab"
                                             Style="{StaticResource TabButton}"
                                             Checked="TabEffect_Checked" />
                            </StackPanel>
                            <Button x:Name="btnLoadImages" Content="📷" ToolTip="加载图片"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Style="{StaticResource GlassButton}" Click="btnLoadImages_Click"
                                    MinWidth="36" Padding="8,4" Margin="0,0,4,0" />
                        </Grid>
                    </Border>

                    <!-- 服装列表 -->
                    <ListBox x:Name="lstClothing" Grid.Row="1"
                             Style="{StaticResource GearListBox}" Margin="4"
                             SelectionChanged="lstClothing_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ItemName}" FontSize="13" Foreground="{DynamicResource TextColor}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="220" />
                                    <TextBlock Text="{Binding EffectBadge}" FontSize="10" Foreground="{DynamicResource StatusTextColor}"
                                               VerticalAlignment="Center" Margin="4,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 特效列表 -->
                    <ListBox x:Name="lstEffect" Grid.Row="1"
                             Style="{StaticResource GearListBox}" Margin="4" Visibility="Collapsed"
                             SelectionChanged="lstEffect_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ItemName}" FontSize="13" Foreground="{DynamicResource TextColor}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="200" />
                                    <TextBlock Text="{Binding EffectBadge}" FontSize="10" Foreground="{DynamicResource StatusTextColor}"
                                               VerticalAlignment="Center" Margin="4,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧：4×2 装备位网格 -->
            <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundColor}" CornerRadius="6" Margin="4,0,0,0">
                <Grid x:Name="slotGrid" Margin="8">
                    <!-- 4列2行，运行时动态填充 -->
                </Grid>
            </Border>
        </Grid>

        <!-- ===== 底部按钮 ===== -->
        <Grid Grid.Row="3" Margin="4,4,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="3.8*" />
            </Grid.ColumnDefinitions>
            <!-- 左侧：方案控制（角色名自动识别） -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,4,0">
                <TextBlock x:Name="labCharName" Text="未识别" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource StatusTextColor}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="txtPresetName" Width="80" Height="32" Background="{DynamicResource TextBoxBackgroundColor}" Foreground="{DynamicResource TextBoxForegroundColor}"
                         CaretBrush="{DynamicResource StatusTextColor}" BorderBrush="{DynamicResource TextBoxBorderColor}" FontSize="12" VerticalContentAlignment="Center"
                         Padding="6,0" Margin="0,0,0,0" />
                <Button x:Name="btnSavePreset" Content="💾 保存"
                        Style="{StaticResource GlassButton}" Click="btnSavePreset_Click" Margin="8,0,0,0" MinWidth="70" />
                <Button x:Name="btnLoadPreset" Content="📂 加载"
                        Style="{StaticResource GlassButton}" Click="btnLoadPreset_Click" Margin="8,0,0,0" MinWidth="70" />
            </StackPanel>
            <!-- 右侧：特效开关 + 确认/还原（与slot卡片右对齐） -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0">
                <CheckBox x:Name="chkEffect" Content="启用特效" FontSize="13" Foreground="{DynamicResource StatusTextColor}"
                          VerticalAlignment="Center" Margin="0,0,16,0"
                          ToolTip="勾选后进场景会卡约5秒（全堆扫描写特效），不勾选则秒进但无特效" />
                <Button x:Name="btnConfirm" Content="✅ 确认变更"
                        Style="{StaticResource GlassButton}" Click="btnConfirm_Click" />
                <Button x:Name="btnRestore" Content="↩ 还原道具"
                        Style="{StaticResource GlassButton}" Click="btnRestore_Click" Margin="16,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- ===== 日志面板（勾选"日志"后显示） ===== -->
        <Border x:Name="logPanel" Grid.Row="4" Background="{DynamicResource LogBackgroundColor}" CornerRadius="4"
                Margin="4,2,4,4" Padding="6" Visibility="Collapsed" MaxHeight="150">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button Grid.Row="0" x:Name="btnCopyLog" Content="复制日志" HorizontalAlignment="Right"
                        FontSize="10" Padding="8,2" Margin="0,0,0,4" Click="btnCopyLog_Click"
                        Background="{DynamicResource LogBackgroundColor}" 
                        Foreground="{DynamicResource StatusTextColor}" BorderThickness="1"
                        Cursor="Hand"/>
                <ListBox Grid.Row="1" x:Name="lstLog" Background="Transparent"
                         Foreground="{DynamicResource StatusTextColor}" FontSize="11" FontFamily="Consolas"
                         BorderThickness="0" VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionMode="Extended" />

            </Grid>
        </Border>
    </Grid>
</Window>
