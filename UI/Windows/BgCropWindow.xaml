<Window x:Class="FS服装搭配专家v1._0.UI.Windows.BgCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="背景修改"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="False">
    <Window.Resources>
        <SolidColorBrush x:Key="GlassCardColor" Color="#15FFFFFF" />
        <SolidColorBrush x:Key="GlassBorderColor" Color="#4DFFFFFF" />
        <SolidColorBrush x:Key="TextColor" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="StatusTextColor" Color="#FF999999" />
        <SolidColorBrush x:Key="ButtonGlassColor" Color="#25FFFFFF" />
        
        <FontFamily x:Key="ThemeFontFamily">Microsoft YaHei</FontFamily>
        <FontWeight x:Key="ThemeFontWeight">Normal</FontWeight>
        
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonGlassColor}" />
            <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
            <Setter Property="FontWeight" Value="{DynamicResource ThemeFontWeight}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                CornerRadius="8" 
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              TextElement.Foreground="{TemplateBinding Foreground}" 
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="GlassComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource GlassCardColor}" />
            <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>
    
    <Border Background="{DynamicResource GlassCardColor}"
            BorderBrush="{DynamicResource GlassBorderColor}"
            BorderThickness="1"
            CornerRadius="16"
            Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                              ShadowDepth="8"
                              Opacity="0.3"
                              Direction="270" />
        </Border.Effect>
        
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="背景修改"
                           FontSize="18"
                           FontFamily="{DynamicResource ThemeFontFamily}"
                           FontWeight="{DynamicResource ThemeFontWeight}"
                           Foreground="{DynamicResource TextColor}" />
                <Button x:Name="btnClose"
                        Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="30"
                        Height="30"
                        Background="Transparent"
                        Foreground="{DynamicResource StatusTextColor}"
                        BorderThickness="0"
                        FontSize="14"
                        Click="btnClose_Click" />
            </Grid>
            
            <!-- 主内容区 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <!-- 左侧：图片预览 -->
                <Border Grid.Column="0"
                        Background="{DynamicResource GlassCardColor}"
                        BorderBrush="{DynamicResource GlassBorderColor}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,0,12,0">
                    <Grid>
                        <Image x:Name="imgPreview"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                        <TextBlock x:Name="txtPreviewPlaceholder"
                                   Text="请选择图片"
                                   FontSize="14"
                                   Foreground="{DynamicResource StatusTextColor}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
                
                <!-- 右侧：设置区 -->
                <StackPanel Grid.Column="1" Width="250">
                    <!-- 图片选择 -->
                    <TextBlock Text="图片选择"
                               FontSize="14"
                               FontFamily="{DynamicResource ThemeFontFamily}"
                               FontWeight="{DynamicResource ThemeFontWeight}"
                               Foreground="{DynamicResource TextColor}"
                               Margin="0,0,0,8" />
                    
                    <Button x:Name="btnBrowse"
                            Content="选择图片..."
                            Style="{StaticResource GlassButton}"
                            HorizontalAlignment="Stretch"
                            Click="btnBrowse_Click"
                            Margin="0,0,0,16" />
                    
                    <!-- 背景类型 -->
                    <TextBlock Text="背景类型"
                               FontSize="14"
                               FontFamily="{DynamicResource ThemeFontFamily}"
                               FontWeight="{DynamicResource ThemeFontWeight}"
                               Foreground="{StaticResource TextColor}"
                               Margin="0,0,0,8" />
                    
                    <ComboBox x:Name="cmbBgType"
                              Style="{StaticResource GlassComboBox}"
                              HorizontalAlignment="Stretch"
                              Height="36"
                              Margin="0,0,0,16" />
                    
                    <!-- 说明 -->
                    <Border Background="{DynamicResource GlassCardColor}"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,16">
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource StatusTextColor}">
                            <Run Text="说明：" FontWeight="600" />
                            <LineBreak />
                            <Run Text="1. 选择一张图片（建议1366x768或等比例）" />
                            <LineBreak />
                            <Run Text="2. 选择要替换的背景类型" />
                            <LineBreak />
                            <Run Text="3. 点击开始处理" />
                            <LineBreak />
                            <Run Text="4. 图片会自动切割并替换游戏背景" />
                        </TextBlock>
                    </Border>
                    
                    <!-- 图片信息 -->
                    <TextBlock x:Name="txtImageInfo"
                               Text=""
                               FontSize="12"
                               Foreground="{DynamicResource StatusTextColor}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                </StackPanel>
            </Grid>
            
            <!-- 状态栏 -->
            <Border Grid.Row="2"
                    Background="{DynamicResource GlassCardColor}"
                    BorderBrush="{DynamicResource GlassBorderColor}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,8"
                    Margin="0,12,0,12">
                <TextBlock x:Name="txtStatus"
                           Text="状态: 准备就绪"
                           FontSize="12"
                           Foreground="{DynamicResource StatusTextColor}" />
            </Border>
            
            <!-- 底部按钮 -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="btnStart"
                        Content="开始处理"
                        Style="{StaticResource GlassButton}"
                        Height="36"
                        MinWidth="100"
                        Click="btnStart_Click"
                        Margin="0,0,8,0" />
                <Button x:Name="btnCancel"
                        Content="关闭"
                        Style="{StaticResource GlassButton}"
                        Height="36"
                        MinWidth="80"
                        Click="btnCancel_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
