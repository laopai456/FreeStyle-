<UserControl x:Class="FS服装搭配专家v1._0.UI.Windows.MapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" 
             d:DesignWidth="900">
    <UserControl.Resources>
        <SolidColorBrush x:Key="GlassCardColor" Color="#15FFFFFF" />
        <SolidColorBrush x:Key="GlassBorderColor" Color="#4DFFFFFF" />
        <SolidColorBrush x:Key="GlassHighlightColor" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="TextColor" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="StatusTextColor" Color="#FF999999" />
        <SolidColorBrush x:Key="TitleTextColor" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="ButtonGlassColor" Color="#25FFFFFF" />
        <SolidColorBrush x:Key="ButtonForegroundColor" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="HoverBackgroundColor" Color="#40FFFFFF" />
        <SolidColorBrush x:Key="PressedBackgroundColor" Color="#40FFFFFF" />
        <SolidColorBrush x:Key="ListItemBackgroundColor" Color="#1AFFFFFF" />
        <SolidColorBrush x:Key="ListItemHoverBackgroundColor" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="ListItemSelectedBackgroundColor" Color="#40FFFFFF" />
        
        <LinearGradientBrush x:Key="NeonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF667EEA" Offset="0" />
            <GradientStop Color="#FF6DD5FA" Offset="0.5" />
            <GradientStop Color="#FFC58AF9" Offset="1" />
        </LinearGradientBrush>
        
        <!-- 
            玻璃拟态按钮样式 - GlassButton
            用途：所有按钮的统一样式
            圆角：8（与标签页一致）
            
            按钮规格：
            - 设置类按钮（选择路径）：Height="36"
            - 操作类按钮（应用地图）：Height="44" Width="160"
        -->
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonGlassColor}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassHighlightColor}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="600" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                CornerRadius="8" 
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter x:Name="ContentPresenter" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              TextElement.Foreground="{TemplateBinding Foreground}" 
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="GlassTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource GlassCardColor}" />
            <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="#40FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="8,6"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="GlassListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="{DynamicResource ListItemBackgroundColor}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Margin" Value="2" />
                        <Setter Property="Padding" Value="10,8" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ListItemHoverBackgroundColor}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundColor}" />
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <ScrollViewer Padding="{TemplateBinding Padding}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- 顶部：地图库路径设置 -->
        <Border Grid.Row="0"
                Background="#15FFFFFF"
                BorderBrush="{DynamicResource GlassBorderColor}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,12"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="地图库："
                           FontSize="14"
                           Foreground="{DynamicResource StatusTextColor}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                
                <Button x:Name="btnBrowseLibrary"
                        Content="选择路径..."
                        Style="{StaticResource GlassButton}"
                        Height="36"
                        MinWidth="100"
                        FontSize="13"
                        Click="btnBrowseLibrary_Click" />
            </StackPanel>
        </Border>
        
        <!-- 中间：地图列表和预览 -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：地图列表 -->
            <Border Grid.Column="0"
                    Background="#15FFFFFF"
                    BorderBrush="{DynamicResource GlassBorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <!-- 搜索框 -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="txtSearch"
                                 Grid.Column="0"
                                 Style="{StaticResource GlassTextBox}"
                                 Height="36"
                                 FontSize="14"
                                 TextChanged="txtSearch_TextChanged" />
                        
                        <Button x:Name="btnSearch"
                                Grid.Column="1"
                                Content="搜索"
                                Style="{StaticResource GlassButton}"
                                Height="36"
                                MinWidth="50"
                                Margin="6,0,0,0"
                                Click="btnSearch_Click" />
                    </Grid>
                    
                    <!-- 地图列表 -->
                    <ListBox x:Name="lstMaps"
                             Grid.Row="1"
                             Style="{StaticResource GlassListBox}"
                             SelectionChanged="lstMaps_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MapName}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextColor}"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            
            <!-- 右侧：预览区域 -->
            <Border Grid.Column="1"
                    Background="#15FFFFFF"
                    BorderBrush="{DynamicResource GlassBorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- 预览图 -->
                    <Border Grid.Row="0"
                            Background="#10FFFFFF"
                            CornerRadius="8"
                            Margin="0,0,0,12">
                        <Image x:Name="imgPreview"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>
                    
                    <!-- 地图名称 -->
                    <TextBlock x:Name="txtMapName"
                               Grid.Row="1"
                               Text="请选择地图"
                               FontSize="14"
                               FontWeight="600"
                               Foreground="{DynamicResource TitleTextColor}"
                               TextAlignment="Center"
                               Margin="0,0,0,12" />
                    
                    <!-- 应用按钮 -->
                    <Button x:Name="btnApply"
                            Grid.Row="2"
                            Content="应用地图"
                            Style="{StaticResource GlassButton}"
                            Height="44"
                            Width="160"
                            HorizontalAlignment="Center"
                            Click="btnApply_Click" />
                </Grid>
            </Border>
        </Grid>
        
        <!-- 底部：状态栏 -->
        <Border Grid.Row="2"
                Background="#10FFFFFF"
                BorderBrush="{DynamicResource GlassBorderColor}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,6"
                Margin="0,0,0,0">
            <TextBlock x:Name="txtStatus"
                       Text="准备就绪"
                       FontSize="12"
                       Foreground="{DynamicResource StatusTextColor}" />
        </Border>
    </Grid>
</UserControl>
