<Window x:Class="FS服装搭配专家v1._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FS服装搭配专家v1._0.UI.Windows"
        Title="FreeStyle"
        Height="768"
        Width="1440"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="White"
        Topmost="True"
        ShowInTaskbar="True">
    <Window.Resources>
        <!-- 颜色资源 - 优化后的玻璃拟态风格 -->
        <SolidColorBrush x:Key="GlassCardColor" Color="#15FFFFFF" /> <!-- 半透明白色卡片（降低透明度，形成层次） -->
        <SolidColorBrush x:Key="GlassCardHoverColor" Color="#40FFFFFF" /> <!-- 悬停/选中状态卡片颜色 -->
        <SolidColorBrush x:Key="GlassBorderColor" Color="#4DFFFFFF" /> <!-- 玻璃边框色 -->
        <SolidColorBrush x:Key="GlassHighlightColor" Color="#20FFFFFF" /> <!-- 玻璃高光边框色，强化边缘切割感 -->
        <SolidColorBrush x:Key="TextColor" Color="#FFFFFFFF" /> <!-- 文本颜色 -->
        <SolidColorBrush x:Key="PreviewTextColor" Color="#FFFFFFFF" /> <!-- 预览文本颜色 -->
        <SolidColorBrush x:Key="StatusTextColor" Color="#FF999999" /> <!-- 状态文本颜色 -->
        <SolidColorBrush x:Key="TitleTextColor" Color="#FFFFFFFF" /> <!-- 标题文本颜色 -->
        <SolidColorBrush x:Key="ButtonGlassColor" Color="#25FFFFFF" /> <!-- 按钮玻璃颜色 -->
        <SolidColorBrush x:Key="ButtonGlassPressedColor" Color="#40FFFFFF" /> <!-- 按钮按下状态颜色 -->
        <SolidColorBrush x:Key="ButtonForegroundColor" Color="#FFFFFFFF" /> <!-- 按钮字体颜色 -->
        <SolidColorBrush x:Key="BodyTextColor" Color="#E6FFFFFF" /> <!-- 正文文本颜色（提高可读性） -->
        <SolidColorBrush x:Key="HoverBackgroundColor" Color="#40FFFFFF" /> <!-- 悬停背景颜色 -->
        <SolidColorBrush x:Key="PressedBackgroundColor" Color="#40FFFFFF" /> <!-- 按下背景颜色 -->
        <SolidColorBrush x:Key="ListItemBackgroundColor" Color="#1AFFFFFF" /> <!-- 列表项背景颜色 -->
        <SolidColorBrush x:Key="ListItemHoverBackgroundColor" Color="#33FFFFFF" /> <!-- 列表项悬停背景颜色 -->
        <SolidColorBrush x:Key="ListItemSelectedBackgroundColor" Color="#33FFFFFF" /> <!-- 列表项选中背景颜色 -->
        <SolidColorBrush x:Key="TabSelectedBackgroundColor" Color="#40FFFFFF" /> <!-- 标签页选中背景颜色 -->
        <SolidColorBrush x:Key="TabHoverBackgroundColor" Color="#25FFFFFF" /> <!-- 标签页悬停背景颜色 -->
        <SolidColorBrush x:Key="TabSelectedForegroundColor" Color="#FFFFFFFF" /> <!-- 标签页选中文字颜色 -->
        <SolidColorBrush x:Key="ContentPanelBackgroundColor" Color="#0DFFFFFF" /> <!-- 内容区域背景颜色 -->
        <SolidColorBrush x:Key="ListItemForegroundColor" Color="#FFFFFFFF" /> <!-- 列表项文字颜色 -->
        
        <!-- 字体资源 -->
        <FontFamily x:Key="ThemeFontFamily">Microsoft YaHei</FontFamily>
        <FontWeight x:Key="ThemeFontWeight">Normal</FontWeight>
        
        <!-- 玻璃拟态文本框样式 -->
        <Style x:Key="GlassTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#20FFFFFF" />
            <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
            <Setter Property="FontWeight" Value="{DynamicResource ThemeFontWeight}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="#40FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="12,8"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 主容器样式 - 优化后的玻璃拟态 -->
        <Style x:Key="MainContainer" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        
        <!-- 标题栏容器样式 -->
        <Style x:Key="TitleBarContainer" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        
        <!-- 霓虹渐变文字效果 -->
        <LinearGradientBrush x:Key="NeonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF667EEA" Offset="0" />
            <GradientStop Color="#FF6DD5FA" Offset="0.5" />
            <GradientStop Color="#FFC58AF9" Offset="1" />
        </LinearGradientBrush>
        
        <!-- 
            玻璃拟态按钮样式 - GlassButton
            用途：所有按钮的统一样式
            圆角：8（与标签页一致）
            
            按钮规格：
            - 设置类按钮（加载图片、选择路径）：Height="36"
            - 操作类按钮（确认变更、清空所有、应用地图）：Height="44" Width="160"
            - 对话框按钮（确定、取消、应用）：Height="40" Width="100"
        -->
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonGlassColor}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassHighlightColor}" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
            <Setter Property="FontWeight" Value="{DynamicResource ThemeFontWeight}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                CornerRadius="8" 
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter x:Name="ContentPresenter" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              TextElement.Foreground="{TemplateBinding Foreground}" 
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{DynamicResource HoverBackgroundColor}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.1" Value="{DynamicResource PressedBackgroundColor}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                           Storyboard.TargetProperty="Effect">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.1">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <DropShadowEffect BlurRadius="8" 
                                                                          ShadowDepth="2" 
                                                                          Opacity="0.05" 
                                                                          Direction="270" 
                                                                          Color="#000000" />
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" 
                                      ShadowDepth="4" 
                                      Opacity="0.1" 
                                      Direction="270" 
                                      Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 窗口管理按钮样式 -->
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonGlassColor}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassHighlightColor}" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                CornerRadius="8" 
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter x:Name="ContentPresenter" 
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="12"
                                              TextElement.FontWeight="Medium" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{DynamicResource HoverBackgroundColor}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.1" Value="{DynamicResource PressedBackgroundColor}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                           Storyboard.TargetProperty="Effect">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.1">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <DropShadowEffect BlurRadius="6" 
                                                                          ShadowDepth="1" 
                                                                          Opacity="0.05" 
                                                                          Direction="270" 
                                                                          Color="#000000" />
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" 
                                      ShadowDepth="2" 
                                      Opacity="0.1" 
                                      Direction="270" 
                                      Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 列表项样式 - 优化后的玻璃拟态 -->
        <Style x:Key="ListItemStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ListItemBackgroundColor}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Margin" Value="4,4,4,0" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" 
                                      ShadowDepth="2" 
                                      Opacity="0.05" 
                                      Direction="270" 
                                      Color="#000000" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundColor}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 选中列表项样式 - 优化后的玻璃拟态 -->
        <Style x:Key="ListItemSelectedStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ListItemSelectedBackgroundColor}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Margin" Value="4,4,4,0" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" 
                                      ShadowDepth="2" 
                                      Opacity="0.1" 
                                      Direction="270" 
                                      Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 预览区域样式 - 优化后的玻璃拟态 -->
        <Style x:Key="PreviewStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource GlassCardColor}" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Margin" Value="0,28,0,0" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Height" Value="400" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassHighlightColor}" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="40" 
                                      ShadowDepth="0" 
                                      Opacity="0.6" 
                                      Direction="270" 
                                      Color="#6DD5FA" />
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 简洁灰白滚动条样式 -->
        <Style x:Key="SimpleGrayScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Background="#20FFFFFF" 
                                    CornerRadius="4" 
                                    Margin="2"/>
                            <Track x:Name="PART_Track" 
                                   IsDirectionReversed="True"
                                   Margin="2">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#80FFFFFF"
                                                        CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 列表框样式 - 优化后的玻璃拟态 -->
        <Style x:Key="GlassListBox" TargetType="ListBox">
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource ListItemForegroundColor}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="Transparent" 
                                BorderBrush="Transparent" 
                                BorderThickness="0">
                            <ScrollViewer x:Name="ScrollViewer" 
                                          Padding="{TemplateBinding Padding}">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource SimpleGrayScrollBar}" />
                                </ScrollViewer.Resources>
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource ListItemForegroundColor}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 修复后的标签页样式 --> 
        <Style x:Key="GlassTabControl" TargetType="TabControl"> 
            <Setter Property="Background" Value="Transparent" /> 
            <Setter Property="BorderThickness" Value="0" /> 
            <Setter Property="Padding" Value="0" /> 
            <Setter Property="Margin" Value="0" /> 
            <Setter Property="Template"> 
                <Setter.Value> 
                    <ControlTemplate TargetType="TabControl"> 
                        <Grid> 
                            <Grid.RowDefinitions> 
                                <RowDefinition Height="*" /> 
                            </Grid.RowDefinitions> 
                            
                            <!-- 内容区域 --> 
                            <Border x:Name="ContentPanel" 
                                    Grid.Row="0" 
                                    Background="{DynamicResource ContentPanelBackgroundColor}" 
                                    BorderBrush="Transparent" 
                                    BorderThickness="0" 
                                    CornerRadius="16" 
                                    Margin="0,0,0,20"> 
                                <Grid> 
                                    <Grid.RowDefinitions> 
                                        <RowDefinition Height="Auto" /> 
                                        <RowDefinition Height="*" /> 
                                    </Grid.RowDefinitions> 
                                    
                                    <!-- 关键修改：将 TabPanel 替换为 StackPanel --> 
                                    <StackPanel x:Name="HeaderPanel" 
                                               Grid.Row="0" 
                                               Panel.ZIndex="2" 
                                               Margin="30,20,0,0" 
                                               IsItemsHost="True" 
                                               HorizontalAlignment="Left" 
                                               Background="Transparent" 
                                               Orientation="Horizontal"/> <!-- 新增 Orientation 确保横向排列 --> 
                                    
                                    <!-- 内容显示 --> 
                                    <ContentPresenter x:Name="PART_SelectedContentHost" 
                                                      Grid.Row="1" 
                                                      Margin="20,20,20,20" 
                                                      ContentSource="SelectedContent" /> 
                                </Grid> 
                            </Border> 
                        </Grid> 
                    </ControlTemplate> 
                </Setter.Value> 
            </Setter> 
        </Style>
        
        <!-- 标签项样式 -->
        <Style x:Key="GlassTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="4,0,4,0" />
            <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
            <Setter Property="FontWeight" Value="{DynamicResource ThemeFontWeight}" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="8"
                                Cursor="Hand"
                                MinWidth="80"
                                Height="36"
                                Margin="0,0,0,0"
                                Padding="12,8">
                            <ContentPresenter x:Name="ContentPresenter"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.FontSize="14"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabSelectedBackgroundColor}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource GlassHighlightColor}" />
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1" />
                                <Setter TargetName="ContentPresenter" Property="TextElement.Foreground" Value="{DynamicResource TabSelectedForegroundColor}" />
                                <Setter TargetName="TabBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="4" 
                                                          ShadowDepth="1" 
                                                          Opacity="0.1" 
                                                          Direction="270" 
                                                          Color="#000000" />
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabHoverBackgroundColor}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource GlassHighlightColor}" />
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <!-- 渐变背景 - 优化后的柔和渐变 -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#6a85b6" Offset="0" />
                <GradientStop Color="#bac8e0" Offset="0.5" />
                <GradientStop Color="#f0c9e8" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        
        <!-- 视频背景层 -->
        <MediaElement x:Name="VideoBackground" 
                      Stretch="UniformToFill" 
                      MediaEnded="VideoBackground_MediaEnded"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Visibility="Collapsed" />
        
        <!-- 窗口拖动区域 -->
        <Grid Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" />
        
        <!-- 主内容区域 -->
        <Border Style="{StaticResource MainContainer}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
            
            <!-- 顶部导航栏 -->
            <Border Grid.Row="0" 
                    Background="Transparent" 
                    BorderBrush="Transparent" 
                    BorderThickness="0" 
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,15,20,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- 标题和控制台开关 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="FreeStyle" 
                                   FontSize="16" 
                                   FontFamily="{DynamicResource ThemeFontFamily}"
                                   FontWeight="{DynamicResource ThemeFontWeight}"
                                   Foreground="{DynamicResource TitleTextColor}"
                                   VerticalAlignment="Center" />
                        
                        <!-- 控制台滑动开关 -->
                        <Grid Name="ConsoleToggleGrid" 
                              Width="32" 
                              Height="16" 
                              Margin="10,0,0,0"
                              Cursor="Hand"
                              MouseLeftButtonDown="ConsoleToggle_MouseLeftButtonDown"
                              ToolTip="控制台开关">
                            <Grid.Resources>
                                <Storyboard x:Key="ToggleOnStoryboard">
                                    <ThicknessAnimation Storyboard.TargetName="ToggleThumb" 
                                                        Storyboard.TargetProperty="Margin"
                                                        To="15,1,1,1" 
                                                        Duration="0:0:0.15" />
                                    <ColorAnimation Storyboard.TargetName="ToggleTrack" 
                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                    To="#4CAF50" 
                                                    Duration="0:0:0.15" />
                                </Storyboard>
                                <Storyboard x:Key="ToggleOffStoryboard">
                                    <ThicknessAnimation Storyboard.TargetName="ToggleThumb" 
                                                        Storyboard.TargetProperty="Margin"
                                                        To="1,1,15,1" 
                                                        Duration="0:0:0.15" />
                                    <ColorAnimation Storyboard.TargetName="ToggleTrack" 
                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                    To="#888888" 
                                                    Duration="0:0:0.15" />
                                </Storyboard>
                            </Grid.Resources>
                            <!-- 轨道背景 -->
                            <Border x:Name="ToggleTrack" 
                                    CornerRadius="8" 
                                    Background="#888888"
                                    BorderThickness="1"
                                    BorderBrush="#666666" />
                            <!-- 滑块 -->
                            <Border x:Name="ToggleThumb" 
                                    CornerRadius="6" 
                                    Background="White"
                                    Width="14"
                                    Height="14"
                                    Margin="1,1,15,1"
                                    HorizontalAlignment="Left"
                                    BorderThickness="1"
                                    BorderBrush="#CCCCCC">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="1" ShadowDepth="0.5" Opacity="0.3" Direction="270" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </StackPanel>
                    
                    <!-- 占位列 -->
                    <Grid Grid.Column="1" />
                    
                    <!-- 右上角按钮组 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        
                        <!-- 换肤按钮 -->
                        <Button Name="btnSkin" 
                                Width="36" 
                                Height="36" 
                                Click="btnSkin_Click"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Margin="0,0,0,0"
                                ToolTip="换肤">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ButtonBorder" 
                                        CornerRadius="10" 
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="Transparent">
                                    <ContentPresenter x:Name="ContentPresenter" 
                                                      Content="{TemplateBinding Content}"
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Margin="4" />
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal" />
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                                   Storyboard.TargetProperty="Background">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{DynamicResource HoverBackgroundColor}" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                                   Storyboard.TargetProperty="BorderBrush">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{DynamicResource GlassBorderColor}" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Pressed">
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                                   Storyboard.TargetProperty="Background">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.1" Value="{DynamicResource PressedBackgroundColor}" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                                   Storyboard.TargetProperty="BorderBrush">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.1" Value="{DynamicResource GlassBorderColor}" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid>
                            <Border Width="24" Height="24">
                                <Border.Background>
                                    <LinearGradientBrush x:Name="IconGradient" StartPoint="-1,-1" EndPoint="2,2">
                                        <GradientStop Color="#FF667EEA" Offset="0" />
                                        <GradientStop Color="#FF6DD5FA" Offset="0.5" />
                                        <GradientStop Color="#FFC58AF9" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.OpacityMask>
                                    <ImageBrush ImageSource="pack://application:,,,/template/vest-l.png" 
                                               Stretch="Uniform" />
                                </Border.OpacityMask>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <PointAnimation 
                                                    Storyboard.TargetName="IconGradient" 
                                                    Storyboard.TargetProperty="StartPoint" 
                                                    From="-1,-1" To="1,1" 
                                                    Duration="0:0:3" 
                                                    AutoReverse="True" />
                                                <PointAnimation 
                                                    Storyboard.TargetName="IconGradient" 
                                                    Storyboard.TargetProperty="EndPoint" 
                                                    From="0,0" To="2,2" 
                                                    Duration="0:0:3" 
                                                    AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                        </Grid>
                    </Button>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 中间内容 -->
            <TabControl Grid.Row="1" Style="{StaticResource GlassTabControl}">
                <!-- 服装搭配标签页 -->
                <TabItem Header="服装道具" Style="{StaticResource GlassTabItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- 左侧服装列表区域 -->
                        <Border Grid.Column="0" Padding="20" CornerRadius="16" Background="Transparent">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                
                                <!-- 搜索区域 -->
                                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,20">
                                    <TextBlock Text="🔍 搜索服装或特效" 
                                               FontSize="14" 
                                               Foreground="{DynamicResource StatusTextColor}" 
                                               Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtSearch" 
                                                 Grid.Column="0"
                                                 Style="{StaticResource GlassTextBox}"
                                                 Height="36" 
                                                 ToolTip="输入服装名称或特效进行搜索" 
                                                 TextChanged="txtSearch_TextChanged" />
                                        <Button x:Name="btnLoadImg" 
                                                Grid.Column="1"
                                                Content="📷 加载图片" 
                                                Style="{StaticResource GlassButton}"
                                                Height="36"
                                                Margin="8,0,0,0"
                                                Click="btnLoadImg_Click" />
                                    </Grid>
                                </StackPanel>
                                
                                <!-- 服装列表和特效列表并排 -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- 左侧：服装列表 -->
                                    <Border Grid.Column="0" Background="#15FFFFFF" 
                                            BorderBrush="{DynamicResource GlassBorderColor}" 
                                            BorderThickness="1" 
                                            CornerRadius="12" 
                                            Padding="8"
                                            MinHeight="200">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="👕 服装列表" 
                                                       FontSize="15" 
                                                       FontFamily="{DynamicResource ThemeFontFamily}"
                                                       FontWeight="{DynamicResource ThemeFontWeight}"
                                                       Foreground="{DynamicResource TitleTextColor}" 
                                                       Margin="0,0,0,8" />
                                            <ListBox x:Name="lstClothing" 
                                                     Grid.Row="1"
                                                     Style="{StaticResource GlassListBox}" 
                                                     SelectionChanged="lstClothing_SelectionChanged"
                                                     Loaded="lstClothing_Loaded">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ItemName}"
                                                                   FontSize="15"
                                                                   FontFamily="{DynamicResource ThemeFontFamily}"
                                                                   FontWeight="{DynamicResource ThemeFontWeight}"
                                                                   Foreground="{DynamicResource ListItemForegroundColor}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- 右侧：特效列表 -->
                                    <Border Grid.Column="2" Background="#15FFFFFF" 
                                            BorderBrush="{DynamicResource GlassBorderColor}" 
                                            BorderThickness="1" 
                                            CornerRadius="12" 
                                            Padding="8"
                                            MinHeight="200">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="✨ 特效列表" 
                                                       FontSize="15" 
                                                       FontFamily="{DynamicResource ThemeFontFamily}"
                                                       FontWeight="{DynamicResource ThemeFontWeight}"
                                                       Foreground="{DynamicResource TitleTextColor}" 
                                                       Margin="0,0,0,8" />
                                            <ListBox x:Name="lstEffect" 
                                                     Grid.Row="1"
                                                     Style="{StaticResource GlassListBox}" 
                                                     SelectionChanged="lstEffect_SelectionChanged">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ItemName}"
                                                                   FontSize="15"
                                                                   FontFamily="{DynamicResource ThemeFontFamily}"
                                                                   FontWeight="{DynamicResource ThemeFontWeight}"
                                                                   Foreground="{DynamicResource ListItemForegroundColor}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </Grid>
                                
                                <!-- 操作提示 -->
                                <StackPanel Grid.Row="3" Margin="0,12,0,0">
                                    <TextBlock Text="服装操作：左键添加到变更前 | Ctrl+左键添加到变更后" 
                                               FontSize="11" 
                                               Foreground="{DynamicResource StatusTextColor}" 
                                               TextAlignment="Center" />
                                    <TextBlock Text="特效操作：先选特效，再Alt+左键点击服装即可添加" 
                                               FontSize="11" 
                                               Foreground="{DynamicResource StatusTextColor}" 
                                               TextAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                
                                <!-- 状态信息 -->
                                <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,12,0,0">
                                    <TextBlock x:Name="labErrorMsg" 
                                               Text="" 
                                               FontSize="12" 
                                               Foreground="#FFFF6B6B" 
                                               Visibility="Collapsed" 
                                               Margin="0,0,0,8" />
                                    <TextBlock x:Name="labLoadingStatus" 
                                               Text="" 
                                               FontSize="11" 
                                               FontFamily="{DynamicResource ThemeFontFamily}"
                                               Foreground="{DynamicResource StatusTextColor}" 
                                               Visibility="Collapsed" 
                                               Margin="0,0,0,8"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                    <Image x:Name="picLoding" 
                                           Source="" 
                                           Width="24" 
                                           Height="24" 
                                           Visibility="Collapsed" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- 右侧变更区域 -->
                        <Border Grid.Column="1" Padding="20" CornerRadius="16" Background="Transparent">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                
                                <!-- 变更区域标题 -->
                                <TextBlock Grid.Row="0" Text="变更区域" 
                                           FontSize="18" 
                                           FontFamily="{DynamicResource ThemeFontFamily}"
                                           FontWeight="{DynamicResource ThemeFontWeight}"
                                           Foreground="{DynamicResource TitleTextColor}" 
                                           Margin="0,0,0,20" />
                                
                                <!-- 配对状态 -->
                                <TextBlock Grid.Row="1" x:Name="txtPairStatus" 
                                           Text="已配对 0 件服装" 
                                           FontSize="12" 
                                           Foreground="{DynamicResource StatusTextColor}" 
                                           Margin="0,0,0,20" />
                                
                                <!-- 变更前和变更后区域 -->
                                <Grid Grid.Row="2" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- 变更前区域 -->
                                    <Border Grid.Column="0" 
                                            Background="#15FFFFFF" 
                                            BorderBrush="{DynamicResource GlassBorderColor}" 
                                            BorderThickness="1" 
                                            CornerRadius="12" 
                                            Padding="16" 
                                            Margin="0,0,10,0">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="变更前" 
                                                       FontSize="14" 
                                                       FontFamily="{DynamicResource ThemeFontFamily}"
                                                       FontWeight="{DynamicResource ThemeFontWeight}"
                                                       Foreground="{DynamicResource TitleTextColor}" 
                                                       Margin="0,0,0,12" />
                                            <Border x:Name="beforePanel" 
                                                    Background="Transparent" 
                                                    MinHeight="200">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <WrapPanel x:Name="beforeWrapPanel"
                                                               Orientation="Horizontal" 
                                                               HorizontalAlignment="Left" 
                                                               VerticalAlignment="Top" 
                                                               ItemWidth="80" 
                                                               ItemHeight="80" 
                                                               Margin="0">
                                                    </WrapPanel>
                                                </ScrollViewer>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- 变更后区域 -->
                                    <Border Grid.Column="1" 
                                            Background="#15FFFFFF" 
                                            BorderBrush="{DynamicResource GlassBorderColor}" 
                                            BorderThickness="1" 
                                            CornerRadius="12" 
                                            Padding="16" 
                                            Margin="10,0,0,0">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="变更后" 
                                                       FontSize="14" 
                                                       FontFamily="{DynamicResource ThemeFontFamily}"
                                                       FontWeight="{DynamicResource ThemeFontWeight}"
                                                       Foreground="{DynamicResource TitleTextColor}" 
                                                       Margin="0,0,0,12" />
                                            <Border x:Name="afterPanel" 
                                                    Background="Transparent" 
                                                    MinHeight="200">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <WrapPanel x:Name="afterWrapPanel"
                                                               Orientation="Horizontal" 
                                                               HorizontalAlignment="Left" 
                                                               VerticalAlignment="Top" 
                                                               ItemWidth="80" 
                                                               ItemHeight="80" 
                                                               Margin="0">
                                                    </WrapPanel>
                                                </ScrollViewer>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                
                                <!-- 操作按钮 -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" 
                                            HorizontalAlignment="Center" 
                                            Margin="0,0,0,20">
                                    <Button x:Name="btnConfirm" 
                                            Content="✅ 确认变更" 
                                            Style="{StaticResource GlassButton}" 
                                            Height="44" 
                                            Width="160" 
                                            Click="btnConfirm_Click" 
                                            Margin="0,0,10,0" />
                                    <Button x:Name="btnClear" 
                                            Content="🗑️ 清空所有" 
                                            Style="{StaticResource GlassButton}" 
                                            Height="44" 
                                            Width="160" 
                                            Click="btnClear_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                
                <!-- 地图切换标签页 -->
                <TabItem Header="地图切换" Style="{StaticResource GlassTabItem}">
                    <local:MapControl x:Name="mapControl" Margin="20" />
                </TabItem>
                
                <!-- 常用工具标签页 -->
                <TabItem Header="常用工具" Style="{StaticResource GlassTabItem}">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0"
                                   Text="常用工具" 
                                   FontSize="18" 
                                   FontFamily="{DynamicResource ThemeFontFamily}"
                                   FontWeight="{DynamicResource ThemeFontWeight}"
                                   Foreground="{DynamicResource TitleTextColor}"
                                   Margin="0,0,0,24" />
                        
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- 背景修改 -->
                            <Border Background="#15FFFFFF"
                                    BorderBrush="{DynamicResource GlassBorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Width="200"
                                    Height="160"
                                    Margin="0,0,24,0"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="btnBgCrop_Click">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="🖼️"
                                                   FontSize="48"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,12" />
                                        <TextBlock Text="背景修改"
                                                   FontSize="16"
                                                   FontWeight="600"
                                                   Foreground="{DynamicResource TextColor}"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="替换游戏背景图片"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource StatusTextColor}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- 补充字节 -->
                            <Border Background="#15FFFFFF"
                                    BorderBrush="{DynamicResource GlassBorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Width="200"
                                    Height="160"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="btnFillBytes_Click">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="📦"
                                                   FontSize="48"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,12" />
                                        <TextBlock Text="补充字节"
                                                   FontSize="16"
                                                   FontWeight="600"
                                                   Foreground="{DynamicResource TextColor}"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="补充PAK文件字节数"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource StatusTextColor}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>