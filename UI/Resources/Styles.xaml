<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <!-- 尺寸常量 -->
    <sys:Double x:Key="ButtonHeight_Small">32</sys:Double>
    <sys:Double x:Key="ButtonHeight_Medium">36</sys:Double>
    <sys:Double x:Key="ButtonHeight_Large">44</sys:Double>
    <sys:Double x:Key="ButtonWidth_Small">80</sys:Double>
    <sys:Double x:Key="ButtonWidth_Medium">120</sys:Double>
    <sys:Double x:Key="ButtonWidth_Large">160</sys:Double>
    <sys:Double x:Key="ButtonWidth_Dialog">100</sys:Double>
    
    <sys:Double x:Key="TextBoxHeight">36</sys:Double>
    <sys:Double x:Key="ComboBoxHeight">36</sys:Double>
    <sys:Double x:Key="TabItemHeight">40</sys:Double>
    
    <sys:Double x:Key="CornerRadius_Small">8</sys:Double>
    <sys:Double x:Key="CornerRadius_Medium">12</sys:Double>
    <sys:Double x:Key="CornerRadius_Large">16</sys:Double>
    
    <sys:Double x:Key="Margin_Small">8</sys:Double>
    <sys:Double x:Key="Margin_Medium">16</sys:Double>
    <sys:Double x:Key="Margin_Large">20</sys:Double>
    
    <sys:Double x:Key="Padding_Small">8</sys:Double>
    <sys:Double x:Key="Padding_Medium">12</sys:Double>
    <sys:Double x:Key="Padding_Large">16</sys:Double>
    
    <!-- 字体大小 -->
    <sys:Double x:Key="FontSize_Tiny">11</sys:Double>
    <sys:Double x:Key="FontSize_Small">12</sys:Double>
    <sys:Double x:Key="FontSize_Normal">14</sys:Double>
    <sys:Double x:Key="FontSize_Medium">15</sys:Double>
    <sys:Double x:Key="FontSize_Large">16</sys:Double>
    <sys:Double x:Key="FontSize_Title">18</sys:Double>
    <sys:Double x:Key="FontSize_Header">24</sys:Double>
    <sys:Double x:Key="FontSize_Display">48</sys:Double>
    
    <!-- 图标尺寸 -->
    <sys:Double x:Key="IconSize_Tiny">14</sys:Double>
    <sys:Double x:Key="IconSize_Small">16</sys:Double>
    <sys:Double x:Key="IconSize_Medium">24</sys:Double>
    <sys:Double x:Key="IconSize_Large">32</sys:Double>
    <sys:Double x:Key="IconSize_XLarge">48</sys:Double>
    
    <!-- 列表项尺寸 -->
    <sys:Double x:Key="ListItemHeight">36</sys:Double>
    <sys:Double x:Key="ListItemIconSize">80</sys:Double>
    
    <!-- 标题栏尺寸 -->
    <sys:Double x:Key="TitleBarHeight">50</sys:Double>
    <sys:Double x:Key="TitleBarIconSize">18</sys:Double>
    
    <!-- 开关控件尺寸 -->
    <sys:Double x:Key="ToggleSwitchTrackWidth">32</sys:Double>
    <sys:Double x:Key="ToggleSwitchTrackHeight">16</sys:Double>
    <sys:Double x:Key="ToggleSwitchThumbSize">14</sys:Double>
    
    <!-- 玻璃拟态文本框样式 -->
    <Style x:Key="GlassTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#20FFFFFF" />
        <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
        <Setter Property="FontWeight" Value="{DynamicResource ThemeFontWeight}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CaretBrush" Value="White" />
        <Setter Property="SelectionBrush" Value="#40FFFFFF" />
        <Setter Property="Height" Value="{StaticResource TextBoxHeight}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadius_Small}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="12,8"
                                      VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 玻璃拟态组合框样式 -->
    <Style x:Key="GlassComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="#20FFFFFF" />
        <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
        <Setter Property="FontWeight" Value="{DynamicResource ThemeFontWeight}" />
        <Setter Property="Height" Value="{StaticResource ComboBoxHeight}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadius_Small}">
                        <Grid>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Margin="12,8"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              IsHitTestVisible="False" />
                            <ToggleButton x:Name="PART_ToggleButton"
                                          Margin="0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Stretch"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Style="{StaticResource ComboBoxToggleButton}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 组合框切换按钮样式 -->
    <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent" Padding="8">
                        <Path x:Name="Arrow"
                              Data="M 0 0 L 8 8 L 16 0"
                              Fill="{DynamicResource TextColor}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 玻璃拟态按钮样式 - 基础 -->
    <Style x:Key="GlassButton_Base" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ButtonGlassColor}" />
        <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassHighlightColor}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
        <Setter Property="FontWeight" Value="{DynamicResource ThemeFontWeight}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder" 
                            CornerRadius="{StaticResource CornerRadius_Small}" 
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter x:Name="ContentPresenter" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center" 
                                          TextElement.Foreground="{TemplateBinding Foreground}" 
                                          TextElement.FontWeight="{TemplateBinding FontWeight}" 
                                          TextElement.FontSize="{TemplateBinding FontSize}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{DynamicResource HoverBackgroundColor}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.1" Value="{DynamicResource PressedBackgroundColor}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" 
                                                                       Storyboard.TargetProperty="Effect">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.1">
                                                <DiscreteObjectKeyFrame.Value>
                                                    <DropShadowEffect BlurRadius="8" 
                                                                      ShadowDepth="2" 
                                                                      Opacity="0.05" 
                                                                      Direction="270" 
                                                                      Color="#000000" />
                                                </DiscreteObjectKeyFrame.Value>
                                            </DiscreteObjectKeyFrame>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="16" 
                                  ShadowDepth="4" 
                                  Opacity="0.1" 
                                  Direction="270" 
                                  Color="#000000" />
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 小按钮样式 -->
    <Style x:Key="GlassButton_Small" BasedOn="{StaticResource GlassButton_Base}" TargetType="Button">
        <Setter Property="Height" Value="{StaticResource ButtonHeight_Small}" />
        <Setter Property="MinWidth" Value="{StaticResource ButtonWidth_Small}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Small}" />
        <Setter Property="Margin" Value="{StaticResource Margin_Small}" />
    </Style>
    
    <!-- 中按钮样式（设置类） -->
    <Style x:Key="GlassButton_Medium" BasedOn="{StaticResource GlassButton_Base}" TargetType="Button">
        <Setter Property="Height" Value="{StaticResource ButtonHeight_Medium}" />
        <Setter Property="MinWidth" Value="{StaticResource ButtonWidth_Medium}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="Margin" Value="{StaticResource Margin_Small}" />
    </Style>
    
    <!-- 大按钮样式（操作类） -->
    <Style x:Key="GlassButton_Large" BasedOn="{StaticResource GlassButton_Base}" TargetType="Button">
        <Setter Property="Height" Value="{StaticResource ButtonHeight_Large}" />
        <Setter Property="Width" Value="{StaticResource ButtonWidth_Large}" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Medium}" />
        <Setter Property="Margin" Value="{StaticResource Margin_Small}" />
    </Style>
    
    <!-- 对话框按钮样式 -->
    <Style x:Key="GlassButton_Dialog" BasedOn="{StaticResource GlassButton_Base}" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Width" Value="{StaticResource ButtonWidth_Dialog}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="Margin" Value="{StaticResource Margin_Small}" />
    </Style>
    
    <!-- 标签页样式 -->
    <Style x:Key="GlassTabItem" TargetType="TabItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="{StaticResource TabItemHeight}" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
        <Setter Property="FontWeight" Value="{DynamicResource ThemeFontWeight}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Medium}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource GlassBorderColor}"
                            BorderThickness="0 0 0 2"
                            CornerRadius="8 8 0 0">
                        <ContentPresenter x:Name="ContentPresenter"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Header}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TabBorder" 
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{DynamicResource TabHoverBackgroundColor}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TabBorder" 
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{DynamicResource TabSelectedBackgroundColor}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" 
                                                                       Storyboard.TargetProperty="TextElement.Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{DynamicResource TabSelectedForegroundColor}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 标签页控件样式 -->
    <Style x:Key="GlassTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="TabStripPlacement" Value="Top" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TabPanel x:Name="HeaderPanel"
                                  Grid.Row="0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  IsItemsHost="True" />
                        <Border x:Name="ContentPanel"
                                Grid.Row="1"
                                Background="{DynamicResource ContentPanelBackgroundColor}"
                                BorderBrush="{DynamicResource GlassBorderColor}"
                                BorderThickness="1"
                                CornerRadius="0 0 {StaticResource CornerRadius_Medium} {StaticResource CornerRadius_Medium}">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Margin="{StaticResource Margin_Medium}"
                                              ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 列表框样式 -->
    <Style x:Key="GlassListBox" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadius_Medium}">
                        <ScrollViewer x:Name="ScrollViewer"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="True">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 列表项样式 -->
    <Style x:Key="GlassListItem" TargetType="ListBoxItem">
        <Setter Property="Background" Value="{DynamicResource ListItemBackgroundColor}" />
        <Setter Property="Foreground" Value="{DynamicResource ListItemForegroundColor}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="4,4,4,0" />
        <Setter Property="Padding" Value="{StaticResource Padding_Medium}" />
        <Setter Property="FontFamily" Value="{DynamicResource ThemeFontFamily}" />
        <Setter Property="FontWeight" Value="{DynamicResource ThemeFontWeight}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource GlassBorderColor}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadius_Medium}">
                        <ContentPresenter x:Name="ContentPresenter"
                                          Margin="{TemplateBinding Padding}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Border" 
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{DynamicResource ListItemHoverBackgroundColor}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Border" 
                                                                       Storyboard.TargetProperty="Opacity">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="0.5" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 主容器样式 -->
    <Style x:Key="MainContainer" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadius_Large}" />
        <Setter Property="Margin" Value="{StaticResource Margin_Small}" />
        <Setter Property="Padding" Value="{StaticResource Margin_Large}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    
    <!-- 卡片容器样式 -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource GlassCardColor}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadius_Medium}" />
        <Setter Property="Margin" Value="{StaticResource Margin_Small}" />
        <Setter Property="Padding" Value="{StaticResource Margin_Medium}" />
    </Style>
    
</ResourceDictionary>
